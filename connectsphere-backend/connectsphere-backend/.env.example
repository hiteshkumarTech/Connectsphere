# ---- Server ----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ---- Database ----
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/connectsphere?retryWrites=true&w=majority

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---- Email (verification + password reset) ----
# Leave SMTP_HOST empty in dev to log email links to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ConnectSphere <no-reply@connectsphere.app>"

# ---- Cloudinary (image uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- AI (OpenAI-compatible: OpenAI, Gemini compat endpoint, OpenRouter, Groq, etc.) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# Set to true to auto-run moderation when a post is created (requires AI key)
AI_MODERATION=false

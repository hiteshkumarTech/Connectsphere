# ---- Local development ----
# Point at your local backend. The socket origin is derived from this
# automatically (it strips the trailing /api), so VITE_SOCKET_URL can stay blank.
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=

# ---- Production (Vercel proxy setup — see DEPLOYMENT.md) ----
# When you proxy /api through Vercel, set these in the Vercel dashboard instead:
#   VITE_API_URL=/api                              (REST goes through the proxy, same-origin)
#   VITE_SOCKET_URL=https://your-backend.onrender.com   (socket connects directly)
